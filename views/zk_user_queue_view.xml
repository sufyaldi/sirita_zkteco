<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="zkteco_user_queue_view_list" model="ir.ui.view">
        <field name="name">zkteco.user.queue.list</field>
        <field name="model">zkteco.user.queue</field>
        <field name="arch" type="xml">
            <list string="Antrean User Mesin" decoration-info="status == 'new'" decoration-success="status == 'mapped'" decoration-muted="status == 'ignored'">
                <field name="zk_pin"/>
                <field name="name"/>
                <field name="device_id"/>
                <field name="status" widget="badge" decoration-info="status == 'new'" decoration-success="status == 'mapped'"/>
                <field name="employee_id"/>
                <button name="action_map_to_employee" string="Petakan ke Employee" type="object" icon="fa-user-plus" invisible="status != 'new'"/>
            </list>
        </field>
    </record>

    <record id="zkteco_user_queue_view_form" model="ir.ui.view">
        <field name="name">zkteco.user.queue.form</field>
        <field name="model">zkteco.user.queue</field>
        <field name="arch" type="xml">
            <form string="Antrean User Mesin">
                <header>
                    <button name="action_map_to_employee" string="Petakan ke Employee" type="object" class="oe_highlight" invisible="status != 'new'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="zk_pin" readonly="1"/>
                            <field name="name"/>
                            <field name="device_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="employee_id" readonly="0"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="zkteco_user_queue_action" model="ir.actions.act_window">
        <field name="name">Antrean User Mesin</field>
        <field name="res_model">zkteco.user.queue</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada data user dari mesin.
            </p>
            <p>
                Gunakan tombol "Tarik User" pada form Mesin untuk mengambil data dari perangkat hardware.
            </p>
        </field>
    </record>

    <menuitem id="menu_zkteco_user_queue"
              name="Antrean User"
              parent="menu_zkteco_root"
              action="zkteco_user_queue_action"
              sequence="20"/>
</odoo>
