<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_zkteco_pin" model="ir.ui.view">
        <field name="name">hr.employee.form.zkteco.pin</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pin']" position="after">
                <field name="zk_pin" string="API/ADMS PIN (Mesin Finger)"/>
            </xpath>
        </field>
    </record>
</odoo>
